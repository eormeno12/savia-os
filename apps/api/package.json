  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main.js",
    "start:worker": "node dist/worker.js",
    "start:mcp": "node dist/mcp.js",
    "typecheck": "tsc --noEmit",
