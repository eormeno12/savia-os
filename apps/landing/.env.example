# Google Sheets waitlist integration
# Paste the full JSON content of a GCP service account key
GOOGLE_SERVICE_ACCOUNT_KEY_JSON=
GOOGLE_SHEETS_ID=
# Sheet tab name (default: waitlist)
GOOGLE_SHEETS_RANGE=waitlist

# Fallback HTTP endpoint (used if Google Sheets is not configured)
WAITLIST_ENDPOINT=

# Upstash Redis — rate limiting (3 req/hora por IP)
# Si no está configurado, el rate limiting se omite sin error
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Demo Mem0 — URL del microservicio demo-api
DEMO_API_URL=http://127.0.0.1:4344

