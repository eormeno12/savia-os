# ── dev defaults (localhost) ────────────────────────────────────────────────
# For local dev copy this file to apps/api/.env (where NestJS reads it).
# For production copy to infra/.env and fill in real values (never commit).

# Postgres
DATABASE_URL=postgresql://savia:savia@localhost:5433/savia

# Redis
REDIS_URL=redis://localhost:6379

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=savia_memories

# OpenAI
OPENAI_API_KEY=

# Auth
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_REFRESH_SECRET=
COOKIE_DOMAIN=localhost

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_SES_FROM=no-reply@savia.com

# Processes
INTERNAL_TOKEN=dev-internal-token
API_PORT=4400
MCP_PORT=4401

# CORS (comma-separated origins in production)
CORS_ORIGIN=http://localhost:4345

# ── production overrides ────────────────────────────────────────────────────
# When running inside Docker Compose the following env vars are injected by
# the compose file and override the DATABASE_URL / REDIS_URL / QDRANT_URL above:
#
#   DATABASE_URL=postgresql://savia:${POSTGRES_PASSWORD}@postgres:5432/savia
#   REDIS_URL=redis://redis:6379
#   QDRANT_URL=http://qdrant:6333
#
# All other secrets must be set in infra/.env (not committed to git):
#
#   POSTGRES_PASSWORD=<strong_password>
#   JWT_SECRET=<64-byte hex>
#   JWT_REFRESH_SECRET=<64-byte hex>
#   OPENAI_API_KEY=sk-...
#   AWS_ACCESS_KEY_ID=AKIA...
#   AWS_SECRET_ACCESS_KEY=...
#   AWS_S3_BUCKET=savia-files-prod
#   AWS_SES_FROM=noreply@savia.com
#   COOKIE_DOMAIN=.savia.com
#   CORS_ORIGIN=https://app.savia.com
#   INTERNAL_TOKEN=<32-byte hex>
