{
  "name": "savia-os",
  "version": "0.0.0",
  "private": true,
  "description": "Savia OS — product monorepo",
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean && find . -name 'node_modules' -type d -prune -exec rm -rf '{}' + 2>/dev/null; true",
    "landing:dev": "turbo dev --filter=@savia-os/landing",
    "landing:build": "turbo build --filter=@savia-os/landing",
    "landing:lint": "turbo lint --filter=@savia-os/landing",
    "landing:typecheck": "turbo typecheck --filter=@savia-os/landing",
    "generate:og": "node scripts/generate-og.mjs",
    "demo-api:dev": "pnpm --filter @savia-os/demo-api dev",
    "api:dev": "turbo dev --filter=@savia-os/api",
    "worker:dev": "pnpm --filter @savia-os/api worker:dev",
    "mcp:dev": "pnpm --filter @savia-os/api mcp:dev",
    "app:dev": "turbo dev --filter=@savia-os/app",
    "infra:up": "docker compose -f infra/docker-compose.yml up -d",
    "infra:down": "docker compose -f infra/docker-compose.yml down",
    "infra:logs": "docker compose -f infra/docker-compose.yml logs -f"
  },
  "devDependencies": {
    "puppeteer-core": "^23.0.0",
    "turbo": "^2.5.4"
  }
}
