{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@savia-os/tsconfig/base",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "dist",
    "rootDir": "src",
    "composite": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
